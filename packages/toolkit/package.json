{
  "name": "@yinxe/toolkit",
  "version": "0.1.0",
  "private": true,
  "description": "Shared build toolkit + UI for MCBE addon monorepo",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./ui": {
      "types": "./src/ui/index.ts",
      "default": "./src/ui/index.ts"
    },
    "./command": {
      "types": "./src/command/index.ts",
      "default": "./src/command/index.ts"
    },
    "./player": {
      "types": "./src/player.ts",
      "default": "./src/player.ts"
    }
  },
  "peerDependencies": {
    "@minecraft/server": ">=2.0.0",
    "@minecraft/server-ui": ">=2.0.0"
  }
}
