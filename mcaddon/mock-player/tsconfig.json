{
    "compilerOptions":{
       "target":"es6",
       "lib": ["es2017"],
       "moduleResolution":"bundler",
       "module": "ES2020",
       "sourceMap":true,
       "pretty":true,
       "forceConsistentCasingInFileNames": true,
       "strict": true,
       "noImplicitAny":true,
       "noImplicitReturns":false,
       "outDir":"lib",
       "rootDir": ".",
       "baseUrl":"BP/",
       "noEmitHelpers":true,
       "skipLibCheck": true
    },
    "include":[
       "scripts/**/*"
    ],
    "exclude": ["lib", "dist", "node_modules"],
    "compileOnSave":false
 }
