# ── 项目配置 ──────────────────────────────────────────────────────
# 设为您的项目名，必须与 BP/<project_name>/ 和 RP/<project_name>/ 一致
PROJECT_NAME="craftablerarities"

# ── Minecraft 部署配置 ───────────────────────────────────────────
# "BedrockGDK" (本地开发) 或 "Preview" (预览版) 或 "Release" (正式版)
MINECRAFT_PRODUCT="BedrockGDK"

# 自定义部署路径（留空使用默认 Minecraft 目录）
CUSTOM_DEPLOYMENT_PATH=""
