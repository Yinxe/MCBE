{
  "name": "@yinxe/mc",
  "version": "1.0.0",
  "private": true,
  "description": "MCBE Addon — Monorepo",
  "keywords": [],
  "author": "Yinx",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.1.3",
      "onFail": "download"
    }
  },
  "type": "module",
  "scripts": {
    "clean": "pnpm -r run clean",
    "build": "pnpm -r run build",
    "build:mock-player": "pnpm --filter mock-player run build",
    "build:craftablerarities": "pnpm --filter craftablerarities run pack",
    "build:keepinventory": "pnpm --filter keepInventory run build",
    "build:smartwarehouse": "pnpm --filter SmartWarehouse run build",
    "lint": "pnpm -r run lint",
    "format": "prettier --write .",
    "sync-version": "node packages/toolkit/bin/sync-version.js"
  }
}
